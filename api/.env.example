# API Configuration (.env)
# ========================================
# Copia este archivo a .env y personaliza los valores

# ========================================
# Base de datos PostgreSQL
# ========================================
DB_HOST=db                              # Host del servidor PostgreSQL
DB_PORT=5432                            # Puerto de PostgreSQL
POSTGRES_DB=clinica_vet                 # Nombre de la base de datos
POSTGRES_USER=miteek                    # Usuario principal de la BD
POSTGRES_PASSWORD=miteek2006            # Contraseña del usuario principal

# ========================================
# Redis (Caché)
# ========================================
REDIS_HOST=redis                        # Host del servidor Redis
REDIS_PORT=6379                         # Puerto de Redis

# ========================================
# Servidor
# ========================================
PORT=3000                               # Puerto donde escucha la API
NODE_ENV=development                    # Ambiente: development | production

# ========================================
# Configuración de Caché
# ========================================
CACHE_TTL=300                           # TTL del caché en segundos (5 min)
CACHE_KEY_VACUNACION=vacunacion:pendiente # Clave de Redis para vacunaciones

# ========================================
# Credenciales de Roles
# Estos usuarios DEBEN existir en PostgreSQL con sus roles asignados
# En producción, usar autenticación JWT + sesiones
# ========================================

# Veterinario
DB_USER_VETERINARIO=dr_lopez            # Usuario de BD para veterinarios
DB_PASS_VETERINARIO=lopez123            # Contraseña

# Recepción
DB_USER_RECEPCION=recepcion1            # Usuario de BD para recepción
DB_PASS_RECEPCION=recep123              # Contraseña

# Administrador
DB_USER_ADMIN=admin_vet                 # Usuario de BD para administradores
DB_PASS_ADMIN=admin123                  # Contraseña

# ========================================
# Ejemplo para Docker Compose:
# ========================================
# DB_HOST=db
# DB_PORT=5432
# REDIS_HOST=redis
# REDIS_PORT=6379
# NODE_ENV=production
