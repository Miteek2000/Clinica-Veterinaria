# Frontend Configuration (.env)
# Copia este archivo a .env y personaliza los valores

# URL del API
# Por defecto detecta automáticamente localhost:3000/api
# En producción, usa la URL real del servidor
# REACT_APP_API_URL=https://api.clinicaveterinaria.com/api
# VUE_APP_API_URL=https://api.clinicaveterinaria.com/api

# Mapeo de roles a vet_id
# Estos valores deberían venir del backend después del login
# Por ahora son valores de ejemplo
# REACT_APP_VET_IDS={"veterinario":1,"recepcion":null,"admin":null}

# TTL del caché en Redis (segundos)
# REACT_APP_CACHE_TTL=300

# Ambiente
NODE_ENV=development
